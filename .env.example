# Upstream MAC Guide — Environment Variables
# Copy to .env.local and fill in your values
# VITE_ prefix required for client-side variables

# Appwrite — matches Upstream Approach pattern
VITE_APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
VITE_APPWRITE_PROJECT_ID=your_project_id_here
VITE_APPWRITE_DB_ID=your_database_id_here

# Appwrite Collection IDs — create these in Appwrite console first
VITE_APPWRITE_COL_JOBSITES=jobsites
VITE_APPWRITE_COL_MATERIALS=materials
VITE_APPWRITE_COL_NOTES=notes
VITE_APPWRITE_COL_CONTACTS=contacts

# Appwrite Storage Bucket
VITE_APPWRITE_BUCKET_PHOTOS=photos
